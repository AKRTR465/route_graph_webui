# Backend bind address. Keep 127.0.0.1 for local-only use.
ROUTE_GRAPH_WEBUI_HOST=127.0.0.1
ROUTE_GRAPH_WEBUI_PORT=8000

# Optional runtime data directory override. Relative paths are resolved by the app.
# ROUTE_GRAPH_WEBUI_DATA_DIR=data

# Frontend dev server API base. Set this in webui_frontend/.env.local or your shell
# before running npm run dev when the backend host/port differs from the default.
VITE_API_BASE=http://127.0.0.1:8000
